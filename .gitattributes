# ✅ FULL FILE VERSION
# .gitattributes - Git Attributes for VecTool Repository

# Office Documents - Binary Files (prevents diff errors)
*.docx binary
*.doc binary
*.pptx binary
*.ppt binary
*.xlsx binary
*.xls binary
*.pdf binary

# Ensure consistent line endings
* text=auto

# C# source files
*.cs text diff=csharp
*.csx text diff=csharp
*.csproj text diff=xml
*.sln text eol=crlf

# Markdown and text files
*.md text
*.txt text
*.json text

# Configuration files
*.config text
*.yml text
*.yaml text
*.xml text

# Scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
*.sh text eol=lf

# Images (binary)
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg text

# Archives (binary)
*.zip binary
*.7z binary
*.tar binary
*.gz binary
