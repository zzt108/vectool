<Window
    x:Class="VecTool.UI.WinUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="VecTool">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Menu Bar -->
        <MenuBar Grid.Row="0">
            <MenuBarItem Title="File">
                <MenuFlyoutItem x:Name="ExitMenuItem" Text="Exit"/>
            </MenuBarItem>
            <MenuBarItem Title="Actions">
                <MenuFlyoutItem x:Name="ConvertToMdMenuItem" Text="Convert to MD"/>
                <MenuFlyoutSeparator/>
                <MenuFlyoutItem x:Name="GetGitChangesMenuItem" Text="Get Git Changes"/>
                <MenuFlyoutItem x:Name="FileSizeSummaryMenuItem" Text="File Size Summary"/>
                <MenuFlyoutItem x:Name="RunTestsMenuItem" Text="Run Tests"/>
            </MenuBarItem>
            <MenuBarItem Title="Help">
                <MenuFlyoutItem x:Name="AboutMenuItem" Text="About"/>
            </MenuBarItem>
        </MenuBar>

        <!-- Tab Control -->
        <TabView Grid.Row="1" Margin="8">
            <!-- Main Tab -->
            <TabViewItem Header="Main">
                <Grid Margin="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Vector Store Management Label -->
                    <TextBlock Grid.Row="0" 
                              Text="Vector Store Management" 
                              FontSize="16" 
                              FontWeight="SemiBold"
                              Margin="0,0,0,10"/>

                    <!-- Vector Store Selection ComboBox -->
                    <ComboBox Grid.Row="1" 
                             x:Name="ComboBoxVectorStores"
                             Header="Vector Store"
                             PlaceholderText="Select a vector store..."
                             HorizontalAlignment="Stretch"
                             Margin="0,0,0,10"
                             SelectionChanged="comboBoxVectorStoresSelectedIndexChanged"/>

                    <!-- New Vector Store Creation -->
                    <StackPanel Grid.Row="2" 
                               Orientation="Horizontal" 
                               Spacing="10"
                               Margin="0,0,0,10">
                        <TextBox x:Name="TxtNewVectorStoreName"
                                PlaceholderText="New vector store name..."
                                Width="400"/>
                        <Button x:Name="BtnCreateNewVectorStore"
                               Content="Create"
                               Click="btnCreateNewVectorStoreClick"/>
                    </StackPanel>

                    <!-- Folder Selection Button -->
                    <Button Grid.Row="3"
                           x:Name="BtnSelectFolders"
                           Content="Select Folders..."
                           Click="btnSelectFoldersClick"
                           HorizontalAlignment="Left"
                           Margin="0,0,0,10"
                           IsEnabled="False"/>

                    <!-- Selected Folders ListView -->
                    <ListView Grid.Row="4"
                             x:Name="LstSelectedFolders"
                             SelectionMode="Single"
                             BorderBrush="{ThemeResource SystemControlForegroundBaseMediumLowBrush}"
                             BorderThickness="1">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" 
                                          TextWrapping="NoWrap"/>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </TabViewItem>

            <!-- Settings Tab -->
            <TabViewItem Header="Settings">
                <ScrollViewer>
                    <StackPanel Margin="16" Spacing="12">
                        <!-- Vector Store Selector -->
                        <TextBlock Text="Vector Store" 
                                  FontWeight="SemiBold"/>
                        <ComboBox x:Name="CmbSettingsVectorStore"
                                 PlaceholderText="Select vector store to configure..."
                                 HorizontalAlignment="Stretch"
                                 SelectionChanged="cmbSettingsVectorStoreSelectedIndexChanged"/>

                        <!-- Inheritance Checkboxes -->
                        <StackPanel Orientation="Horizontal" Spacing="20" Margin="0,10,0,0">
                            <CheckBox x:Name="chkInheritExcludedFiles"
                                     Content="Inherit Excluded Files from Global"
                                     Checked="chkInheritExcludedFilesCheckedChanged"
                                     Unchecked="chkInheritExcludedFilesCheckedChanged"/>
                            <CheckBox x:Name="chkInheritExcludedFolders"
                                     Content="Inherit Excluded Folders from Global"
                                     Checked="chkInheritExcludedFoldersCheckedChanged"
                                     Unchecked="chkInheritExcludedFoldersCheckedChanged"/>
                        </StackPanel>

                        <!-- Excluded Files TextBox -->
                        <TextBlock Text="Excluded Files (one pattern per line)" 
                                  FontWeight="SemiBold"
                                  Margin="0,15,0,5"/>
                        <TextBox x:Name="TxtExcludedFiles"
                                PlaceholderText="e.g., *.tmp, *.log"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Height="120"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <!-- Excluded Folders TextBox -->
                        <TextBlock Text="Excluded Folders (one name per line)" 
                                  FontWeight="SemiBold"
                                  Margin="0,15,0,5"/>
                        <TextBox x:Name="TxtExcludedFolders"
                                PlaceholderText="e.g., bin, obj"
                                AcceptsReturn="True"
                                TextWrapping="Wrap"
                                Height="120"
                                ScrollViewer.VerticalScrollBarVisibility="Auto"/>

                        <!-- Save/Reset Buttons -->
                        <StackPanel Orientation="Horizontal" 
                                   HorizontalAlignment="Right" 
                                   Spacing="10"
                                   Margin="0,20,0,0">
                            <Button x:Name="BtnSaveVsSettings"
                                   Content="Save"
                                   Style="{StaticResource AccentButtonStyle}"
                                   Click="btnSaveVsSettingsClick"/>
                            <Button x:Name="BtnResetVsSettings"
                                   Content="Reset"
                                   Click="btnResetVsSettingsClick"/>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabViewItem>

            <!-- Recent Files Tab (Placeholder) -->
            <TabViewItem Header="Recent Files">
                <Grid>
                    <TextBlock Text="Recent Files functionality coming soon..."
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center"
                              FontSize="16"
                              Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                </Grid>
            </TabViewItem>
        </TabView>

        <!-- Status Bar -->
        <Grid Grid.Row="2" 
              Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
              Padding="12,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="StatusLabel"
                      Grid.Column="0"
                      Text="Ready"
                      VerticalAlignment="Center"/>

            <ProgressBar x:Name="ProgressBar"
                        Grid.Column="1"
                        Width="200"
                        Height="16"
                        Visibility="Collapsed"/>
        </Grid>
    </Grid>
</Window>
