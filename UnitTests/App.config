<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <appSettings>
    <!-- Test-specific values -->
    <add key="recentFilesMaxCount" value="7" />
    <add key="recentFilesRetentionDays" value="30" />
    <add key="recentFilesOutputPath" value="%APPDATA%\VecTool\TestGenerated" />
    <!-- AI Prompts Library Configuration (4.6.1.1) -->
    <add key="promptsRepositoryPath" value="C:\Git\AiPrompts" />
    <add key="promptsFileExtensions" value=".md,.txt,.yaml,.json" />
    <add key="llmProviderConfig" value="C:\Git\AiPrompts\llm-config.json" />
    <add key="favoritesConfigPath" value="C:\Git\AiPrompts\.favorites.json" />

  </appSettings>
</configuration>
