<!-- ✅ FULL FILE VERSION -->
<!-- Path: UI/VecTool.UI.WinUI/Pages/RecentFilesPage.xaml -->
<Page
    x:Class="VecTool.UI.WinUI.Pages.RecentFilesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:VecTool.UI.WinUI.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Filter Controls -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Padding="16,8" Spacing="8">
            <TextBlock Text="Filter:" VerticalAlignment="Center"/>

            <ComboBox x:Name="Filter" 
                      Width="150" 
                      SelectionChanged="FilterSelectionChanged">
                <x:String>All</x:String>
                <x:String>Linked</x:String>
                <x:String>Unlinked</x:String>
                <x:String>Specific Store</x:String>
            </ComboBox>

            <ComboBox x:Name="SpecificStore" 
                      Width="200" 
                      Visibility="Collapsed"
                      SelectionChanged="SpecificStoreSelectionChanged"/>
        </StackPanel>

        <!-- Recent Files GridView with Context Menu -->
        <GridView x:Name="Files"
                  Grid.Row="1"
                  SelectionMode="Single"
                  IsItemClickEnabled="True"
                  ItemClick="FilesItemClick"
                  Padding="8"
                  CanDragItems="True"
                  AllowDrop="True">

            <!-- ✅ NEW: Context Menu -->
            <GridView.ContextFlyout>
                <MenuFlyout>
                    <MenuFlyoutItem x:Name="MenuOpenFile" 
                                    Text="Open File" 
                                    Click="MenuOpenFile_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8E5;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>

                    <MenuFlyoutItem x:Name="MenuOpenFolder" 
                                    Text="Open Containing Folder" 
                                    Click="MenuOpenFolder_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8B7;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>

                    <MenuFlyoutItem x:Name="MenuCopyPath" 
                                    Text="Copy Path" 
                                    Click="MenuCopyPath_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE8C8;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>

                    <MenuFlyoutSeparator/>

                    <MenuFlyoutItem x:Name="MenuRemove" 
                                    Text="Remove from List" 
                                    Click="MenuRemove_Click">
                        <MenuFlyoutItem.Icon>
                            <FontIcon Glyph="&#xE74D;"/>
                        </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                </MenuFlyout>
            </GridView.ContextFlyout>

            <!-- Item Template -->
            <GridView.ItemTemplate>
                <DataTemplate>
                    <StackPanel Width="300" Padding="8">
                        <TextBlock Text="{Binding Path}" 
                                   FontWeight="SemiBold" 
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding LinkedStoreName}" 
                                   Foreground="Gray" 
                                   FontSize="12"
                                   Visibility="{Binding IsLinked}"/>
                    </StackPanel>
                </DataTemplate>
            </GridView.ItemTemplate>

            <!-- Item Container Style for Selection -->
            <GridView.ItemContainerStyle>
                <Style TargetType="GridViewItem">
                    <Setter Property="Margin" Value="4"/>
                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                </Style>
            </GridView.ItemContainerStyle>
        </GridView>
    </Grid>
</Page>
