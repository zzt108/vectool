<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <!-- 
      Test-specific settings for the recent files manager. 
      These are typically overridden during test execution.
    -->
    <add key="recentFilesMaxCount" value="7" />
    <add key="recentFilesRetentionDays" value="30" />
    <add key="recentFilesOutputPath" value="APPDATA" />

    <!-- 
      ✅ NEW: Explicitly define global exclusion lists for the test environment.
      This ensures that tests relying on global configuration have predictable, non-empty values,
      satisfying the precondition for ShouldLoadCorrectExclusionSettings.
      The values should align with the defaults provided in VectorStoreConfig.
    -->
    <add key="excludedFiles" value=".bin,.exe,.dll,.pdb,*.log" />
    <add key="excludedFolders" value="bin,obj,.git,.vs,packages" />

  </appSettings>
</configuration>
